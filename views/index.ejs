<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= project.title %> — <%= project.author %></title>
  <meta name="description" content="<%= project.intro %>" />

  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['"Fraunces"', 'serif'],
            sans: ['"Inter"', 'sans-serif'],
          },
          colors: { ink: '#0a0a0a', paper: '#f5f3ef', accent: '#ffd60a' },
        },
      },
    };
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,600;9..144,900&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

  <link rel="stylesheet" href="/css/style.css" />

  <!-- Données images exposées au JS pour le mode Parcours -->
  <script id="images-data" type="application/json"><%- JSON.stringify(images) %></script>
</head>
<body class="bg-paper text-ink font-sans antialiased" data-mode="index">

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-40 px-6 md:px-12 py-5 flex justify-between items-center">
    <span class="font-display text-xl font-semibold mix-blend-difference text-paper"><%= project.author %></span>
    <div class="flex items-center gap-6">
      <span class="text-xs uppercase tracking-widest mix-blend-difference text-paper hidden md:inline"><%= project.year %></span>
      <!-- Toggle mode -->
      <button id="mode-toggle" class="group flex items-center gap-2 text-xs uppercase tracking-widest px-3 py-2 rounded-full border border-ink/20 bg-paper/80 backdrop-blur hover:bg-ink hover:text-paper transition-colors" aria-label="Changer de mode d'affichage">
        <span class="mode-label-index">Index</span>
        <span class="mode-label-parcours hidden">Parcours</span>
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform group-hover:rotate-180">
          <path d="M3 7h8M7 3v8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero-section min-h-screen flex flex-col justify-end px-6 md:px-12 pb-20 pt-32">
    <p class="hero-tag text-sm uppercase tracking-[0.3em] text-ink/60 mb-6"><%= project.subtitle %> · 2019-2026 - Cédric Stoecklin</p>
    <h1 class="font-display font-black leading-none tracking-tight text-[clamp(4rem,16vw,18rem)]">
      <span class="block"><span class="inline-block hero-line"><%= project.title %></span></span>
    </h1>
    <p class="reveal max-w-4xl mt-12 font-display text-xl md:text-2xl leading-snug text-ink/80"><%= project.intro %></p>
  </section>

  <!-- MODE B : INDEX (masonry) — visible par défaut -->
  <section id="mode-index" class="px-6 md:px-12 pb-32">
    <div class="flex justify-between items-baseline mb-8  mx-auto">
      <p class="text-xs uppercase tracking-widest text-ink/50">Galerie</p>
      <p class="text-xs uppercase tracking-widest text-ink/50">Cliquez pour agrandir</p>
    </div>

    <div class="masonry mx-auto">
      <% images.forEach((img, i) => { %>
        <figure class="masonry-item group cursor-pointer" data-index="<%= i %>" data-orientation="<%= img.orientation %>">
          <div class="relative overflow-hidden bg-ink/5">
            <img src="<%= img.src %>" alt="<%= img.caption %>" loading="lazy" class="w-full h-auto block transition-transform duration-700 group-hover:scale-[1.03]" />
            <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/10 transition-colors"></div>
          </div>
          <figcaption class="mt-2 flex justify-between items-baseline text-xs text-ink/60">
            <span><%= img.caption %></span>
            <span class="font-mono"><%= String(i + 1).padStart(2, '0') %> / <%= String(images.length).padStart(2, '0') %></span>
          </figcaption>
        </figure>
      <% }) %>
    </div>
  </section>

  <!-- MODE A : PARCOURS — Codrops grid-to-preview -->
  <section id="mode-parcours" class="hidden">
    <% panels.forEach((panel, pIdx) => { %>
      <div class="parcours-panel" data-panel="<%= pIdx %>">
        <!-- Grille 4x2 plein écran -->
        <div class="parcours-grid">
          <% panel.images.forEach((imgIdx, tIdx) => { %>
            <% const img = images[imgIdx]; %>
            <figure class="product" data-index="<%= tIdx %>" data-img="<%= imgIdx %>" data-name="<%= img.caption %>" data-num="<%= String(imgIdx + 1).padStart(2, '0') %> / <%= String(images.length).padStart(2, '0') %>">
              <img src="<%= img.src %>" alt="<%= img.caption %>" class="product-thumb" loading="lazy" />
            </figure>
          <% }) %>
        </div>

        <!-- Preview gauche (s'ouvre quand on hover cols 2-3) -->
        <div class="product-preview --left">
          <div class="preview-stage">
            <img class="preview-img" src="" alt="" />
            <div class="masked-preview"></div>
          </div>
          <div class="product-meta">
            <span class="product-num font-mono"></span>
            <p class="product-title font-display"></p>
          </div>
        </div>

        <!-- Preview droite (s'ouvre quand on hover cols 0-1) -->
        <div class="product-preview --right">
          <div class="preview-stage">
            <img class="preview-img" src="" alt="" />
            <div class="masked-preview"></div>
          </div>
          <div class="product-meta">
            <span class="product-num font-mono"></span>
            <p class="product-title font-display"></p>
          </div>
        </div>
      </div>
    <% }) %>
  </section>

  <!-- TIMELINE bar — toujours en bas -->
  <aside id="timeline" class="fixed bottom-0 left-0 right-0 z-30 px-4 py-3 bg-paper/90 backdrop-blur-md border-t border-ink/10">
    <div class="flex items-center gap-3  mx-auto">
      <span class="text-[10px] uppercase tracking-widest text-ink/50 font-mono whitespace-nowrap hidden md:inline" id="timeline-counter">01 / <%= String(images.length).padStart(2, '0') %></span>
      <div class="flex-1 overflow-x-auto scrollbar-hide">
        <div class="flex gap-1.5 min-w-max">
          <% images.forEach((img, i) => { %>
            <button class="timeline-thumb group relative shrink-0 w-8 h-8 md:w-10 md:h-10 overflow-hidden" data-index="<%= i %>" aria-label="Image <%= i + 1 %>">
              <img src="<%= img.src %>" alt="" class="w-full h-full object-cover opacity-50 group-hover:opacity-100 transition-opacity" />
            </button>
          <% }) %>
        </div>
      </div>
      <button id="timeline-collapse" class="text-[10px] uppercase tracking-widest text-ink/50 hover:text-ink whitespace-nowrap" aria-label="Replier la timeline">Réduire</button>
    </div>
  </aside>

  <!-- LIGHTBOX -->
  <div id="lightbox" class="fixed inset-0 z-50 bg-ink/95 hidden items-center justify-center p-6 md:p-12" role="dialog" aria-modal="true">
    <button class="absolute top-6 right-6 text-paper/70 hover:text-paper text-2xl" id="lightbox-close" aria-label="Fermer">×</button>
    <button class="absolute left-6 top-1/2 -translate-y-1/2 text-paper/70 hover:text-paper text-3xl" id="lightbox-prev" aria-label="Précédente">‹</button>
    <button class="absolute right-6 top-1/2 -translate-y-1/2 text-paper/70 hover:text-paper text-3xl" id="lightbox-next" aria-label="Suivante">›</button>
    <figure class="max-w-[90vw] max-h-[85vh] flex flex-col items-center gap-4">
      <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[75vh] object-contain" />
      <figcaption class="text-paper/70 text-sm flex gap-6">
        <span id="lightbox-caption"></span>
        <span id="lightbox-counter" class="font-mono"></span>
      </figcaption>
    </figure>
  </div>

  <!-- FOOTER -->
<footer class="site-footer border-t border-ink/10 px-6 md:px-12 py-16">
  <div class="site-footer__inner max-w-[1800px] mx-auto w-full">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-14 text-sm leading-relaxed">

      <!-- COL 1 : bio / démarche -->
      <div class="space-y-8">
        <div>
          <p class="font-display text-xl font-semibold tracking-tight">CÉDRIC STOECKLIN</p>
          <p class="text-ink/60 mt-1">Né en 1979, vit et travaille à Annecy</p>
          <p class="mt-3">
            <a href="https://www.cedricstoecklin.com" target="_blank" rel="noopener" class="underline underline-offset-4 decoration-ink/30 hover:decoration-accent">www.cedricstoecklin.com</a><br />
            <a href="mailto:hey@cedricstoecklin.com" class="underline underline-offset-4 decoration-ink/30 hover:decoration-accent">hey@cedricstoecklin.com</a>
          </p>
        </div>

        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-ink/50 mb-2">Démarche</p>
          <p class="text-ink/80">
            Développe depuis 2020 <span class="font-semibold">URBAN YELLOW</span>,
            recherche photographique personnelle autour de l'insertion d'une
            figure récurrente dans des architectures contemporaines.
          </p>
        </div>

        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-ink/50 mb-2">Commande publique</p>
          <p class="text-ink/80">
            <span class="font-mono text-ink/50 mr-2">2022</span>Déclinaison territoriale de la série URBAN YELLOW, commande acquise par la Communauté d'agglomération Paris-Saclay.
          </p>
        </div>

        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-ink/50 mb-2">Activité</p>
          <p class="text-ink/80">
            Photographe d'architecture et de design depuis 2019, Annecy.
          </p>
        </div>
      </div>

      <!-- COL 2 : liste des œuvres -->
      <div>
        <p class="text-[10px] uppercase tracking-[0.2em] text-ink/50 mb-4">Liste des œuvres</p>
        <p class="text-ink/70 text-xs leading-relaxed">
          Photographies, tirages pigmentaires sur papier Hahnemühle.
          Édition de 13 + 2EA. Formats disponibles: 40×50 cm, 60x75 cm, 80×100 cm et 100x125 cm.
        </p>
        <ul class="mt-5 divide-y divide-ink/10 font-mono text-[11px] uppercase tracking-wider">
          <li class="flex justify-between py-2"><span>L'envol</span><span class="text-ink/50">2024</span></li>
          <li class="flex justify-between py-2"><span>Paix</span><span class="text-ink/50">2022</span></li>
          <li class="flex justify-between py-2"><span>Convergence</span><span class="text-ink/50">2020</span></li>
          <li class="flex justify-between py-2"><span>Messe</span><span class="text-ink/50">2026</span></li>
          <li class="flex justify-between py-2"><span>Accès</span><span class="text-ink/50">2025</span></li>
          <li class="flex justify-between py-2"><span>La tour</span><span class="text-ink/50">2025</span></li>
          <li class="flex justify-between py-2"><span>H</span><span class="text-ink/50">2023</span></li>
          <li class="flex justify-between py-2"><span>Passage</span><span class="text-ink/50">2023</span></li>
          <li class="flex justify-between py-2"><span>Escalier</span><span class="text-ink/50">2023</span></li>
          <li class="flex justify-between py-2"><span>Confrontation</span><span class="text-ink/50">2023</span></li>
          <li class="flex justify-between py-2"><span>Courbes</span><span class="text-ink/50">2022</span></li>
          <li class="flex justify-between py-2"><span>Galerie</span><span class="text-ink/50">2022</span></li>
          <li class="flex justify-between py-2"><span>Orange</span><span class="text-ink/50">2022</span></li>
          <li class="flex justify-between py-2"><span>Pointe</span><span class="text-ink/50">2022</span></li>
          <li class="flex justify-between py-2"><span>Tiret</span><span class="text-ink/50">2022</span></li>
          <li class="flex justify-between py-2"><span>Vague</span><span class="text-ink/50">2022</span></li>
          <li class="flex justify-between py-2"><span>Antenne</span><span class="text-ink/50">2021</span></li>
          <li class="flex justify-between py-2"><span>De nuit</span><span class="text-ink/50">2021</span></li>
          <li class="flex justify-between py-2"><span>Passerelle</span><span class="text-ink/50">2021</span></li>
          <li class="flex justify-between py-2"><span>Réflexion</span><span class="text-ink/50">2021</span></li>
          <li class="flex justify-between py-2"><span>Z</span><span class="text-ink/50">2021</span></li>
          <li class="flex justify-between py-2"><span>Bonbon</span><span class="text-ink/50">2020</span></li>
          <li class="flex justify-between py-2"><span>Infini</span><span class="text-ink/50">2020</span></li>
          <li class="flex justify-between py-2"><span>///</span><span class="text-ink/50">2020</span></li>
        </ul>
      </div>

      <!-- COL 3 : colophon / acquisition -->
      <div class="space-y-8">
        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-ink/50 mb-2">Acquisition</p>
          <p class="text-ink/80">
            Tirages disponibles sur commande. Chaque pièce est livrée signée,
            numérotée et accompagnée d'un certificat d'authenticité.
          </p>
          <a href="mailto:hey@cedricstoecklin.com?subject=URBAN%20YELLOW%20%E2%80%94%20demande%20de%20tirage" class="inline-block mt-4 text-xs uppercase tracking-widest border border-ink/20 px-4 py-2 rounded-full hover:bg-ink hover:text-paper transition-colors">
            Demander un tirage →
          </a>
        </div>

        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-ink/50 mb-2">Colophon</p>
          <p class="text-ink/80">
            Prises de vue réalisées au format numérique, 2020–2026.
            Post-production numérique en insertion, tirages calibrés et réalisés en France.
          </p>
        </div>

        <div>
          <p class="text-[10px] uppercase tracking-[0.2em] text-ink/50 mb-2">Suivre</p>
          <ul class="space-y-1">
            <li><a href="https://www.instagram.com/cedricstoecklin_photographe/" class="underline underline-offset-4 decoration-ink/30 hover:decoration-accent">Instagram — @cedricstoecklin</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bas de footer -->
    <div class="mt-12 pt-6 border-t border-ink/10 flex flex-col md:flex-row justify-between items-start md:items-center gap-3 text-[11px] uppercase tracking-widest text-ink/50">
      <span>© 2026 Cédric Stoecklin — Tous droits réservés</span>
      <span>Urban Yellow — 24 fragments, 2020–2026</span>
    </div>
  </div>
</footer>

  <script src="/js/main.js"></script>
</body>
</html>
